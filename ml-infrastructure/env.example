# Medical AI Model Training & Serving Environment Variables

# ML Model Server Configuration
ML_MODEL_SERVER_URL=http://localhost:8000
ML_SERVER_HOST=0.0.0.0
ML_SERVER_PORT=8000

# Supabase Configuration (for edge functions)
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
ML_MODEL_SERVER_URL=http://your-ml-server-url:8000

# AI API Keys (fallback options)
OPENAI_API_KEY=your_openai_api_key
GEMINI_API_KEY=your_gemini_api_key

# Training Configuration
WANDB_PROJECT=vision-weave-med
WANDB_ENTITY=your_username
MLFLOW_TRACKING_URI=http://localhost:5000

# Hardware Configuration
CUDA_VISIBLE_DEVICES=0
NUM_WORKERS=4
BATCH_SIZE=32

# Dataset Paths
DATA_DIR=./data
MODELS_DIR=./models
LOGS_DIR=./logs

# Security
API_KEY=your_secure_api_key
JWT_SECRET=your_jwt_secret

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
